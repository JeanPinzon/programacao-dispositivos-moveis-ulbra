# Modulo 6: modelo de credenciais de assinatura.
# Copie este arquivo para "keystore.properties" (sem .example) e preencha com os
# seus dados. O arquivo real e ignorado pelo Git (veja .gitignore) e NUNCA deve
# ser compartilhado. A perda da keystore impede publicar atualizacoes do app.

storeFile=minha-chave.jks
storePassword=SUA_SENHA_DA_KEYSTORE
keyAlias=chave-do-app
keyPassword=SUA_SENHA_DA_CHAVE
